#include "juego.h"
#include "consola.h"
#include <iostream>

using namespace std;

Juego::Juego(int ancho, int alto) {
    m_tablero = CrearTablero(ancho, alto);
    m_puntaje = 0;
    m_lineasCompletadas = 0;
    m_gameOver = false;
    
    // Configuracion de CLI pura
    OcultarCursor();
}

Juego::~Juego() {
    // Al destruirse la clase, limpia TODA la memoria del heap. Cero Memory Leaks.
    DestruirTablero(m_tablero);
}

void Juego::GenerarNuevaPieza() {
    m_activa.forma = GenerarPiezaAleatoria();
    m_activa.x = (m_tablero->ancho / 2) - 2; // Centrada horizontalmente
    m_activa.y = -3; // Nace virtualmente "arriba" del tablero para bajar de forma suave
    
    // Detectar Game Over: Si al nacer EN LA POSICION 0 (top visible) y choca de frente... se acabo todo
    if (ColisionPieza(m_tablero, m_activa.forma, m_activa.x, 0)) {
        m_gameOver = true;
    }
}

// Este es el Renderizador a Bajo Nivel. Pinta usando `#`
void Juego::Dibujar() {
    MoverCursor(0, 0); // Regresa al inicio de la consola para no parpadear system("cls")
    
    cout << "== TETRIS UNIVERSITARIO C++ ==" << endl;
    cout << " PTS: " << m_puntaje << " | LINEAS: " << m_lineasCompletadas << " \n\n";

    for (int y = 0; y < m_tablero->alto; ++y) {
        cout << "<!"; // Pared V-Izquierda
        
        for (int x = 0; x < m_tablero->ancho; ++x) {
            bool celdaDibujadaComoActual = false;
            
            // Prioridad 1: Dibujar la mascara de 4x4 si cruza con este pixel
            // Para eso chequemos si el XY esta en el radio [x, x+3], [y, y+3]
            if (x >= m_activa.x && x < m_activa.x + 4 && y >= m_activa.y && y < m_activa.y + 4) {
                int px = x - m_activa.x;
                int py = y - m_activa.y;
                int bit_viejo = 15 - (py * 4 + px);
                
                // Extraemos logicamente
                if (m_activa.forma & (1 << bit_viejo)) {
                    cout << "#"; // Dibuja la que esta cayendo vivo
                    celdaDibujadaComoActual = true;
                }
            }
            
            // Prioridad 2: Imprimir piezas ya muertas atrapadas en la memoria del tablero
            if (!celdaDibujadaComoActual) {
                if (CeldaOcupada(m_tablero, x, y)) {
                    cout << "#"; // En memoria
                } else {
                    cout << "."; // Espacio disponible
                }
            }
        }
        cout << "!>\n"; // Pared V-Derecha
    }
    
    // Piso Subterraneo inferior
    cout << "<!";
    for (int x = 0; x < m_tablero->ancho; ++x) {
        cout << "=";
    }
    cout << "!>\n";
    
    cout << "\n Controles de CLI: \n";
    cout << " [A] Izquierda | [D] Derecha | [S] Acelerar | [W] RotDer | [Q] RotIzq\n";
    cout << " [ESC] Salir\n";
}

void Juego::ManejarEntradaAsincrona() {
    if (LetraPresionada()) {
        int tecla = ObtenerLetra();
        MascaraPieza testRot = 0; // Backup virtual
        
        switch (tecla) {
        case 'a': case 'A':
            // Choca si me muevo a la izq?
            if (!ColisionPieza(m_tablero, m_activa.forma, m_activa.x - 1, m_activa.y)) {
                m_activa.x--;
            }
            break;
        case 'd': case 'D':
            // Choca si me muevo a la der?
            if (!ColisionPieza(m_tablero, m_activa.forma, m_activa.x + 1, m_activa.y)) {
                m_activa.x++;
            }
            break;
        case 's': case 'S':
            BajarPiezaGravedad();
            break;
        case 'w': case 'W':
            testRot = RotarDerecha(m_activa.forma);
            if (!ColisionPieza(m_tablero, testRot, m_activa.x, m_activa.y)) m_activa.forma = testRot;
            break;
        case 'q': case 'Q':
            testRot = RotarIzquierda(m_activa.forma);
            if (!ColisionPieza(m_tablero, testRot, m_activa.x, m_activa.y)) m_activa.forma = testRot;
            break;
        case 27: // Codigo ASCII de Tecla Esc = 27
            m_gameOver = true;
            break;
        }
    }
}

// Empuja hacia abajo. Si choca, entierra todo el shape.
void Juego::BajarPiezaGravedad() {
    if (!ColisionPieza(m_tablero, m_activa.forma, m_activa.x, m_activa.y + 1)) {
        m_activa.y++;
    } else {
        // Boom! 
        FijarPieza(m_tablero, m_activa.forma, m_activa.x, m_activa.y); 
        
        // Exterminar lineas matematicamente
        int limpiadas = LimpiarFilas(m_tablero);
        if (limpiadas > 0) {
            m_lineasCompletadas += limpiadas;
            // Estandar tetris BPS system scoring
            if (limpiadas == 1) m_puntaje += 40;
            if (limpiadas == 2) m_puntaje += 100;
            if (limpiadas == 3) m_puntaje += 300;
            if (limpiadas == 4) m_puntaje += 1200;
        }
        
        GenerarNuevaPieza();
    }
}

void Juego::Iniciar() {
    GenerarNuevaPieza();
    
    // Reloj interno de motor primitivo
    int tiempoDiferencialMs = 0;
    
    while (!m_gameOver) {
        ManejarEntradaAsincrona();
        Dibujar();
        
        Dormir(30); // 30ms sleep da FPS de ~ 33fps
        tiempoDiferencialMs += 30;
        
        // Gravedad artificial, baja un bloque cada "velocidadGravedad" milisegundos
        int velocidadGravedad = 600 - (m_lineasCompletadas * 10);
        if (velocidadGravedad < 100) velocidadGravedad = 100; // Limite humano maximo de Hard Drop
        
        if (tiempoDiferencialMs >= velocidadGravedad) {
            BajarPiezaGravedad();
            tiempoDiferencialMs = 0;
        }
    }
    
    cout << "\n\n   >>> FIN DEL JUEGO <<<   \n";
}
