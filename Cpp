#include "consola.h"
#include <windows.h>
#include <conio.h>

// Justificacion: Evita el parpadeo molesto del cursor mientras el motor
// de renderizado dibuja el tablero usando iteraciones.
void OcultarCursor() {
    HANDLE consola = GetStdHandle(STD_OUTPUT_HANDLE);
    CONSOLE_CURSOR_INFO info;
    info.dwSize = 100;
    info.bVisible = FALSE;
    SetConsoleCursorInfo(consola, &info);
}

// Justificacion: En lugar de usar system("cls") que causa flickering extremo,
// movemos el cursor al inicio (0,0) y sobreescribimos los caracteres.
void MoverCursor(int x, int y) {
    HANDLE consola = GetStdHandle(STD_OUTPUT_HANDLE);
    COORD pos;
    pos.X = x;
    pos.Y = y;
    SetConsoleCursorPosition(consola, pos);
}

// Justificacion: Lectura no bloqueante del teclado (_kbhit).
// Esto permite que la pieza caiga por gravedad aunque el usuario no presione nada.
bool LetraPresionada() {
    return _kbhit() != 0;
}

// Justificacion: Obtiene el caracter del buffer sin imprimirlo en pantalla.
int ObtenerLetra() {
    return _getch();
}

// Justificacion: Pausa el hilo de ejecucion usando Sleep de Windows 
// para controlar los Ticks (fotogramas por segundo) del Game Loop.
void Dormir(int milisegundos) {
    Sleep(milisegundos);
}



