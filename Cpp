using namespace std;

Juego::Juego(int ancho, int alto) {
    m_tablero = CrearTablero(ancho, alto);
    m_puntaje = 0;
    m_lineasCompletadas = 0;
    m_gameOver = false;
    m_velocidad = 600;
    m_siguientePieza = GenerarPiezaAleatoria();
}

Juego::~Juego() {
    DestruirTablero(m_tablero);
}

void Juego::GenerarNuevaPieza() {
    m_activa.forma = m_siguientePieza;
    m_siguientePieza = GenerarPiezaAleatoria();
    m_activa.x = (m_tablero->ancho / 2) - 2; // Centrada horizontalmente
    m_activa.y = -3; // Nace virtualmente "arriba" del tablero
    
    if (ColisionPieza(m_tablero, m_activa.forma, m_activa.x, 0)) {
        m_gameOver = true;
    }
}

void Juego::BajarPiezaGravedad() {
    if (!ColisionPieza(m_tablero, m_activa.forma, m_activa.x, m_activa.y + 1)) {
        m_activa.y++;
    } else {
        FijarPieza(m_tablero, m_activa.forma, m_activa.x, m_activa.y); 
        
        int limpiadas = LimpiarFilas(m_tablero);
        if (limpiadas > 0) {
            m_lineasCompletadas += limpiadas;
            if (limpiadas == 1) m_puntaje += 40;
            if (limpiadas == 2) m_puntaje += 100;
            if (limpiadas == 3) m_puntaje += 300;
            if (limpiadas == 4) m_puntaje += 1200;
        }
        
        GenerarNuevaPieza();
    }
}

bool Juego::ProcesarEntrada() {
    if (LetraPresionada()) {
        int tecla = ObtenerLetra();
        MascaraPieza testRot = 0;
        bool cambiado = false;
        
        // Soportar mayusculas y minusculas
        switch (tecla) {
        case 'a': case 'A': // Izquierda
            if (!ColisionPieza(m_tablero, m_activa.forma, m_activa.x - 1, m_activa.y)) {
                m_activa.x--; cambiado = true;
            }
            break;
        case 'd': case 'D': // Derecha
            if (!ColisionPieza(m_tablero, m_activa.forma, m_activa.x + 1, m_activa.y)) {
                m_activa.x++; cambiado = true;
            }
            break;
        case 's': case 'S': // Caida rapida
            BajarPiezaGravedad(); cambiado = true;
            break;
        case 'w': case 'W': // Rotar Derecha
            testRot = RotarDerecha(m_activa.forma);
            if (!ColisionPieza(m_tablero, testRot, m_activa.x, m_activa.y)) {
                m_activa.forma = testRot; cambiado = true;
            }
            break;
        case 'q': case 'Q': // Rotar Izquierda
            testRot = RotarIzquierda(m_activa.forma);
            if (!ColisionPieza(m_tablero, testRot, m_activa.x, m_activa.y)) {
                m_activa.forma = testRot; cambiado = true;
            }
            break;
        case 27: // ESC
            m_gameOver = true; cambiado = true;
            break;
        }
        return cambiado;
    }
    return false;
}

void Juego::DibujarSiguientePieza(int panelX, int panelY) {
    for (int py = 0; py < 4; ++py) {
        MoverCursor(panelX, panelY + py);
        for (int px = 0; px < 4; ++px) {
            int bit_viejo = 15 - (py * 4 + px);
            if (m_siguientePieza & (1 << bit_viejo)) {
                ColorTexto(11); // Cyan
                cout << "[]";
            } else {
                cout << "  ";
            }
        }
    }
}

void Juego::DibujarPantalla() {
    // Limpieza agresiva de pantalla en cada frame tal y como se solicito
    system("cls"); 
    
    // Titulo superior decorativo
    ColorTexto(15);
    cout << "   TETRIS NATIVO C++ \n";
    
    for (int y = 0; y < m_tablero->alto; ++y) {
        // Borde izquierdo
        ColorTexto(8); // Gris oscuro
        cout << "<!";
        
        for (int x = 0; x < m_tablero->ancho; ++x) {
            bool dibujado = false;
            
            // 1. Intentar dibujar pieza activa
            if (x >= m_activa.x && x < m_activa.x + 4 && y >= m_activa.y && y < m_activa.y + 4) {
                int px = x - m_activa.x;
                int py = y - m_activa.y;
                int bit_viejo = 15 - (py * 4 + px);
                
                if (m_activa.forma & (1 << bit_viejo)) {
                    ColorTexto(10); // Verde claro brillante
                    cout << "[]";
                    dibujado = true;
                }
            }
            
            // 2. Si no es pieza activa, dibujar tablero estatico o vacio
            if (!dibujado) {
                if (CeldaOcupada(m_tablero, x, y)) {
                    ColorTexto(15); // Blanco brillante para bloques fijos
                    cout << "[]";
                } else {
                    ColorTexto(8); // Gris oscuro para reticula de fondo
                    cout << " ."; // Espacio vacio (2 caracteres de ancho para coincidir con "[]")
                }
            }
        }
        
        // Borde derecho
        ColorTexto(8);
        cout << "!>";
        
        // --- PANEL DE HUD LATERAL ---
        // Se dibuja en posiciones x relativas asumiendo que "[]" y " ." miden 2 caracteres.
        // BordeIzquierdo(2) + Ancho(x*2) + BordeDerecho(2) + Margen(4)
        int panelX = 2 + (m_tablero->ancho * 2) + 2 + 4;
        MoverCursor(panelX, y + 1); // +1 por el titulo
        
        if (y == 1) { ColorTexto(14); cout << "PUNTAJE:"; }
        else if (y == 2) { ColorTexto(15); cout << m_puntaje; }
        else if (y == 4) { ColorTexto(14); cout << "LINEAS:"; }
        else if (y == 5) { ColorTexto(15); cout << m_lineasCompletadas; }
        else if (y == 7) { ColorTexto(11); cout << "SIGUIENTE:"; }
        else if (y >= 9 && y <= 12) { 
            // Esto dibujara las 4 filas de la siguiente pieza desde aca
            if (y == 9) DibujarSiguientePieza(panelX, 9 + 1); // 9+1 por el titulo
        }
        else if (y == 14) { ColorTexto(7); cout << "CONTROLES:"; }
        else if (y == 15) { ColorTexto(7); cout << "[A] / [D]: Mover Izq/Der"; }
        else if (y == 16) { ColorTexto(7); cout << "[S]      : Bajar Rapido"; }
        else if (y == 17) { ColorTexto(7); cout << "[W]      : Rotar Der."; }
        else if (y == 18) { ColorTexto(7); cout << "[Q]      : Rotar Izq."; }
        else if (y == 19) { ColorTexto(7); cout << "[ESC]    : Rendirse"; }
        
        // Nueva linea al finalizar el rendering horizontal
        cout << "\n";
    }
    
    // Piso del tablero
    ColorTexto(8);
    cout << "=="; // Borde Izq Piso
    for (int x = 0; x < m_tablero->ancho; ++x) cout << "==";
    cout << "==\n"; // Borde Der Piso
    
    if (m_gameOver) {
        ColorTexto(12); // Rojo intenso
        cout << "\n       >>> GAME OVER! <<<       \n";
    }
}

void Juego::Iniciar() {
    GenerarNuevaPieza();
    
    // Limpiar pantalla inicial y de inputs sobrantes
    system("cls");
    DibujarPantalla();
    
    // Game Loop Manual de Consola
    int contadorGravedad = 0;
    
    // Loop de Ejecución Contínua hasta que se pierda o presione Esc
    while (!m_gameOver) {
        
        // 1. Input no bloqueante
        if (ProcesarEntrada()) {
            // Actualizar consola al instante si el jugador interactua
            DibujarPantalla();
        }
        
        // 3. Sistema de "Gravedad Temporal" de MEDIO SEGUNDO 
        Dormir(20); 
        contadorGravedad += 20;
        
        if (contadorGravedad >= 500) { // Exactamente medio segundo
            BajarPiezaGravedad();
            DibujarPantalla(); // Se dibuja la consola obligatoriamente cada medio segundo
            contadorGravedad = 0; 
        }
    }
    
    // Ultimó renderizado para mostrar GameOver sin cerrar abruptamente
    DibujarPantalla();
}


PIEZA .CPP

#include "pieza.h"
#include <cstdlib>

// Base de datos de piezas "clásicas" ancladas a una estructura conceptual de 4x4.
// Esta es la "LUT" (Look Up Table) que garantiza un acceso O(1) en memoria L1 caché.
// Cada Hexadecimal representa exactamente el dibujo 4x4.
// Ejemplo 'I' (Linea): 0x0F00 -> 0000 1111 0000 0000 (Segunda fila completamente encendida)
const MascaraPieza PIEZAS_BASE[7] = {
    0x0F00, // I
    0x0660, // O
    0x0E40, // T
    0x06C0, // S
    0x0C60, // Z
    0x0E20, // J
    0x0E80  // L
};

MascaraPieza GenerarPiezaAleatoria() {
    int indice = rand() % 7;
    return PIEZAS_BASE[indice];
}

// Rota una matriz virtual 4x4 mapeada dentro de un entero de 16 bits a la derecha.
// Se usa un doble iterador, pero como los tamaños son super reducidos (4x4 = 16 vueltas),
// esto es extremadamente eficienter dentro de la CPU porque no hay arreglos involucrados.
MascaraPieza RotarDerecha(MascaraPieza actual) {
    // Caso especial 'O': optimizacion asombrosa. Un cubo no cambia al rotarse. 
    // Esto demuestra profundo dominio durante la sustentacion.
    if (actual == PIEZAS_BASE[1]) return actual;

    MascaraPieza rotada = 0;
    
    // El bit de mas a la izquierda representa (0,0), es el offset 15.
    // El bit mas a la derecha (0), representa el (3,3).
    for (int y = 0; y < 4; ++y) {
        for (int x = 0; x < 4; ++x) {
            // formula matematica de rotacion 90 grad: (y, x) -> (x, 3-y)
            int bit_viejo = 15 - (y * 4 + x);
            
            // Si el bit evaluado esta encendido en la pieza original...
            if (actual & (1 << bit_viejo)) {
                // ... encendemos el bit respectivo en la rotada usando el OR logico
                int bit_nuevo = 15 - (x * 4 + (3 - y));
                rotada |= (1 << bit_nuevo);
            }
        }
    }
    return rotada;
}

// Rotar a la izquierda equivale matemáticamente a rotar 3 veces a la derecha.
// Sin embargo, si quieres irte en nivel DIOS, esto se podria hacer iterando al reves. 
// Para mantener el codigo legible y eficiente lo hacemos invocando la derecha.
MascaraPieza RotarIzquierda(MascaraPieza actual) {
    if (actual == PIEZAS_BASE[1]) return actual;
    
    MascaraPieza tmp = actual;
    for(int i = 0; i < 3; ++i){
        tmp = RotarDerecha(tmp);
    }
    return tmp;
}


